# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local, Neon, Railway, etc. Remote hosts use TLS automatically (see src/config/db.js).
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d

# ─── Default Admin Credentials (Used by db:init on first deploy) ──────────────
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=YourStrongPassword@2026

# ─── SMTP (Gmail App Password) ────────────────────────────────────────────────
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="My Big Dream" <your_gmail@gmail.com>

# ─── Twilio WhatsApp (optional) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_ADMIN_PHONE=+91xxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=My Big Dream
# Required in production — set to your Vercel frontend URL
FRONTEND_URL=https://mybigdream.vercel.app
# Optional — extra allowed browser origins (comma-separated), e.g. Vercel preview URLs
# ADDITIONAL_CORS_ORIGINS=https://my-app-git-main-team.vercel.app

# ─── Vercel (set in Project → Settings → Environment Variables) ───────────────
# Root Directory for this API project must be: backEnd
# NODE_ENV is production on Vercel — all variables above that are required in production must be set.
# VERCEL=1 is injected automatically; used to tune the DB pool for serverless.
# Frontend VITE_API_URL should be the API base including /api, e.g. https://big-dream-api.vercel.app/api
